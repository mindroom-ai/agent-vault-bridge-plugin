#!/usr/bin/env sh
set -eu

token="${AGENT_VAULT_PROXY_TOKEN:-}"
if [ -z "$token" ]; then
  echo "gh-via-broker: AGENT_VAULT_PROXY_TOKEN is not set" >&2
  exit 2
fi

ca_path="${AGENT_VAULT_CA_PATH:-/etc/ssl/agent-vault-ca.pem}"
proxy="${HTTPS_PROXY:-https://127.0.0.1:14322}"
self_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

find_real() {
  name="$1"
  old_ifs="$IFS"
  IFS=:
  for dir in $PATH; do
    IFS="$old_ifs"
    [ -n "$dir" ] || continue
    [ "$dir" = "$self_dir" ] && continue
    [ "$dir" = "$self_dir/bin" ] && continue
    if [ -x "$dir/$name" ]; then
      printf '%s\n' "$dir/$name"
      return 0
    fi
    IFS=:
  done
  IFS="$old_ifs"
  return 1
}

curl_bin="$(find_real curl)"

if [ "${1:-}" = "api" ]; then
  shift
  if [ $# -lt 1 ]; then
    echo "gh-via-broker: gh api requires an endpoint" >&2
    exit 2
  fi
  endpoint="$1"
  shift
  case "$endpoint" in
    http://*|https://*) url="$endpoint" ;;
    /*) url="https://api.github.com$endpoint" ;;
    *) url="https://api.github.com/$endpoint" ;;
  esac
  exec "$curl_bin" \
    -sS \
    --max-time "${AGENT_VAULT_CURL_MAX_TIME:-30}" \
    --proxy "$proxy" \
    --proxy-cacert "$ca_path" \
    --proxy-insecure \
    --cacert "$ca_path" \
    --proxy-header "Proxy-Authorization: Bearer $token" \
    "$url" \
    "$@"
fi

echo "gh-via-broker: only 'gh api <endpoint>' is brokered by this plugin" >&2
exit 2
